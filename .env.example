APP_NAME=BantuDelice
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bantudelice
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── MTN MoMo ────────────────────────────────────────────────────────────────
# Sandbox  : MOMO_ENVIRONMENT=sandbox  + MOMO_TARGET_ENVIRONMENT=sandbox
# Production Congo : MOMO_ENVIRONMENT=production + MOMO_TARGET_ENVIRONMENT=mtncongo
MOMO_ENVIRONMENT=sandbox
MOMO_TARGET_ENVIRONMENT=sandbox

# Collections (paiements entrants — requestToPay)
MOMO_COLLECTIONS_PRIMARY_KEY=
MOMO_COLLECTIONS_SECONDARY_KEY=
MOMO_COLLECTIONS_SUBSCRIPTION_KEY=
MOMO_COLLECTIONS_API_USER=
MOMO_COLLECTIONS_API_KEY=

# Disbursements (paiements sortants — transfer)
MOMO_DISBURSEMENTS_PRIMARY_KEY=
MOMO_DISBURSEMENTS_SECONDARY_KEY=
MOMO_DISBURSEMENTS_SUBSCRIPTION_KEY=
MOMO_DISBURSEMENTS_API_USER=
MOMO_DISBURSEMENTS_API_KEY=

# Remittances — non utilisé en production BantuDelice, préparer uniquement si activé
MOMO_REMITTANCES_PRIMARY_KEY=
MOMO_REMITTANCES_SECONDARY_KEY=
MOMO_REMITTANCES_SUBSCRIPTION_KEY=
MOMO_REMITTANCES_API_USER=
MOMO_REMITTANCES_API_KEY=

# Callback & proxy disbursement
MOMO_CALLBACK_URL=
MOMO_USE_CALLBACK_HEADER=true
MOMO_DISBURSEMENT_PROXY_ENABLED=false
MOMO_DISBURSEMENT_PROXY_URL=
MOMO_DISBURSEMENT_PROXY_STATUS_URL=
MOMO_DISBURSEMENT_PROXY_TOKEN=
MOMO_DISBURSEMENT_PROXY_TIMEOUT=90
MOMO_DISBURSEMENT_PROXY_SOURCE_IP=

# ─── Airtel Money ─────────────────────────────────────────────────────────────
AIRTEL_MONEY_ENABLED=false
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
AIRTEL_MONEY_ENVIRONMENT=sandbox
AIRTEL_MONEY_CALLBACK_URL=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ─── PayPal ───────────────────────────────────────────────────────────────────
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# ─── Firebase / FCM ───────────────────────────────────────────────────────────
FCM_ENABLED=true
FCM_SERVER_KEY=
FCM_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_ENABLED=true
GOOGLE_MAPS_API_KEY=

# ─── Pusher / Broadcasting ────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
