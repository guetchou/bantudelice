APP_NAME=BantuDelice
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bantudelice
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

# ─── GePay Gateway ─────────────────────────────────────────────────────────────
GEPAY_ENABLED=true
GEPAY_REQUIRE_NONCE=true
GEPAY_SIGNATURE_TOLERANCE_SECONDS=300
GEPAY_SUBMISSION_CLAIM_TIMEOUT_SECONDS=120
GEPAY_DEFAULT_PROVIDER=mtn_momo
GEPAY_INTERNAL_CLIENT_UUID=

GEPAY_BANTUDELICE_COLLECTIONS_ENABLED=false
GEPAY_BANTUDELICE_WITHDRAWALS_ENABLED=false

GEPAY_MTN_ENABLED=false
GEPAY_MTN_ENVIRONMENT=sandbox
GEPAY_MTN_TARGET_ENVIRONMENT=sandbox
GEPAY_MTN_SANDBOX_URL=https://sandbox.momodeveloper.mtn.com
GEPAY_MTN_PRODUCTION_URL=https://proxy.momoapi.mtn.com
GEPAY_MTN_CALLBACK_URL=

GEPAY_MTN_COLLECTIONS_SUBSCRIPTION_KEY=
GEPAY_MTN_COLLECTIONS_API_USER=
GEPAY_MTN_COLLECTIONS_API_KEY=

GEPAY_MTN_DISBURSEMENTS_SUBSCRIPTION_KEY=
GEPAY_MTN_DISBURSEMENTS_API_USER=
GEPAY_MTN_DISBURSEMENTS_API_KEY=

GEPAY_MTN_REMITTANCES_ENABLED=false
GEPAY_MTN_REMITTANCES_SUBSCRIPTION_KEY=
GEPAY_MTN_REMITTANCES_API_USER=
GEPAY_MTN_REMITTANCES_API_KEY=
GEPAY_MTN_REMITTANCES_TOKEN_PATH=

# ─── MTN MoMo historique ──────────────────────────────────────────────────────
MOMO_ENVIRONMENT=sandbox
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_COLLECTIONS_PRIMARY_KEY=
MOMO_COLLECTIONS_SECONDARY_KEY=
MOMO_COLLECTIONS_SUBSCRIPTION_KEY=
MOMO_COLLECTIONS_API_USER=
MOMO_COLLECTIONS_API_KEY=
MOMO_DISBURSEMENTS_PRIMARY_KEY=
MOMO_DISBURSEMENTS_SECONDARY_KEY=
MOMO_DISBURSEMENTS_SUBSCRIPTION_KEY=
MOMO_DISBURSEMENTS_API_USER=
MOMO_DISBURSEMENTS_API_KEY=
MOMO_REMITTANCES_PRIMARY_KEY=
MOMO_REMITTANCES_SECONDARY_KEY=
MOMO_REMITTANCES_SUBSCRIPTION_KEY=
MOMO_REMITTANCES_API_USER=
MOMO_REMITTANCES_API_KEY=
MOMO_CALLBACK_URL=
MOMO_USE_CALLBACK_HEADER=true
MOMO_DISBURSEMENT_PROXY_ENABLED=false
MOMO_DISBURSEMENT_PROXY_URL=
MOMO_DISBURSEMENT_PROXY_STATUS_URL=
MOMO_DISBURSEMENT_PROXY_TOKEN=
MOMO_DISBURSEMENT_PROXY_TIMEOUT=90
MOMO_DISBURSEMENT_PROXY_SOURCE_IP=

# ─── MTN Congo Tinda SMS ──────────────────────────────────────────────────────
# Token récupéré dans Profil > Info API sur la plateforme Tinda.
# Ne jamais committer le token réel.
MTN_TINDA_ENABLED=false
MTN_TINDA_API_URL=https://sms.mtncongo.net/api/sms/
MTN_TINDA_TOKEN=
MTN_TINDA_AUTH_PREFIX=Token
MTN_TINDA_SENDER_ID=BantuDelice
MTN_TINDA_CALLBACK_URL=
MTN_TINDA_TIMEOUT=15
MTN_TINDA_RETRY_TIMES=1
MTN_TINDA_RETRY_SLEEP_MS=300

# ─── Airtel Money ─────────────────────────────────────────────────────────────
AIRTEL_MONEY_ENABLED=false
AIRTEL_MONEY_CLIENT_ID=
AIRTEL_MONEY_CLIENT_SECRET=
AIRTEL_MONEY_ENVIRONMENT=sandbox
AIRTEL_MONEY_CALLBACK_URL=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_ENABLED=false
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ─── PayPal ───────────────────────────────────────────────────────────────────
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

# ─── Firebase / FCM ───────────────────────────────────────────────────────────
FCM_ENABLED=true
FCM_SERVER_KEY=
FCM_SENDER_ID=
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_ENABLED=true
GOOGLE_MAPS_API_KEY=

# ─── Pusher / Broadcasting ────────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
