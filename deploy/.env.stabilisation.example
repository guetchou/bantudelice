# Copier vers deploy/.env.stabilisation puis remplacer les valeurs.
# Ne jamais versionner le fichier contenant les vrais secrets.

REDIS_PASSWORD=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
UPTIME_KUMA_PORT=3001

# Paramètres à reporter dans le .env Laravel de production :
# CACHE_DRIVER=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis
# REDIS_CLIENT=predis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=<même secret que REDIS_PASSWORD>
# REDIS_PORT=6379
# REDIS_DB=0
# REDIS_CACHE_DB=1
